# Domain (Caddy will auto-provision TLS via Let's Encrypt)
DOMAIN=cleanbank.example.com

# Postgres
POSTGRES_DB=cleanbank
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# RabbitMQ
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=change-me

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-long-random-hex
JWT_ISSUER=https://cleanbank.example.com
JWT_AUDIENCE=cleanbank-clients
JWT_EXPIRATION=3600000

# CORS: browser-facing frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=https://cleanbank.example.com

# Frontend: base URL the browser will call (public API URL)
NEXT_PUBLIC_API_URL=https://cleanbank.example.com/api
